node_modules/
dist/
*.log
*.tsbuildinfo
.env
.env.local
*.db
*.sqlite
*.sqlite-journal
.DS_Store
Thumbs.db
.vscode/
.idea/
coverage/

# tsx temp cache — created with a literal "undefined" dir name when
# launched under certain sanitized environments (boot-test debris).
undefined/

# Claude Code per-project settings — may contain tenant URLs / users
.claude/settings.local.json
.claude/settings.json

# Transformers.js cache (lazy-downloaded models)
.cache/

# Capitu generated artifacts — keep folder structure, ignore contents.
# Files written by capituSpecExportDocx, capituDevDocumentObject, etc.
capitu-output/**
!capitu-output/README.md
!capitu-output/.gitkeep
!capitu-output/*/
!capitu-output/*/.gitkeep

# Project-level MCP config — generated locally per user via SETUP.md.
# Use .mcp.example.json as template.
.mcp.json

# Multi-instance profiles — contain tenant host/user. Local only.
# Use instances.example.json as template; real file lives in ~/.capitu/.
instances.json

# Smoke / integration scripts — local only (hit live SAP).
scripts/smoke-test-adt*.ts
scripts/integration-test-adt.ts

# Case n8n/Telegram — material pessoal fora do escopo do produto.
# A coleção Postman e o guia gerado contêm host/usuário do tenant.
# Mantidos localmente, nunca versionados.
postman/
gen-guia-case-n8n.js
Guia-Case-n8n-SAP.docx
