{
  "name": "capitu-mcp",
  "version": "0.0.1",
  "private": true,
  "description": "Ecossistema de MCPs SAP cooperativos com Knowledge Base compartilhada e aprendizado contínuo (capitu-docs, capitu-dev, capitu-spec)",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check packages",
    "format": "biome format --write packages",
    "typecheck": "tsc -b",
    "smoke:adt": "tsx scripts/smoke-test-adt.ts",
    "smoke:adt:v2": "tsx scripts/smoke-test-adt-v2.ts",
    "integration:adt": "tsx scripts/integration-test-adt.ts",
    "warmup:embeddings": "tsx scripts/warmup-embeddings.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "abap-adt-api": "^8.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
