# Copy to .env (gitignored) and fill in your values.
# Used by scripts/smoke-test-adt.ts and future capitu-dev MCP.

# SAP connection — required
SAP_URL=https://<seu-tenant-sap>:<porta>
SAP_USER=<seu-usuario>
SAP_PASSWORD=<sua-senha>
SAP_CLIENT=<mandant>
SAP_LANGUAGE=<idioma>  # ex: PT, EN, DE

# KB / embeddings — required for capitu-docs
CAPITU_KB_PATH=
VOYAGE_API_KEY=

# Safety / compliance — defaults are safe; uncomment to override
# CAPITU_ALLOW_WRITES=false
# CAPITU_ALLOWED_PACKAGES=$TMP
# CAPITU_COMPLIANCE_MODE=strict
# CAPITU_I_UNDERSTAND_API_POLICY_RISK=
